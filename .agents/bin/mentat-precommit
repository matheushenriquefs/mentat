#!/usr/bin/env bash
# bin/mentat-precommit — dispatch per-class precommit check, invoked by lefthook.
# Usage: mentat-precommit <class> <file> [<file> ...]
set -euo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
. "$HERE/lib/strict.sh"
# shellcheck source=/dev/null
. "$HERE/lib/precommit-gates.sh"

CLASS="${1:?usage: mentat-precommit <class> <file> [...]}"
shift

# Infer and run the appropriate gate for a file based on its path.
# Returns 1 if the gate fails, 0 if it passes or no gate applies.
gate_auto() {
  local f="$1"
  case "$f" in
    */docs/adr/*.md)             gate_adr      "$f" ;;
    */skills/*/SKILL.md)         gate_skill    "$f" ;;
    */commands/*.md)             gate_command  "$f" ;;
    */.github/workflows/*.yml|\
    */.github/workflows/*.yaml)  gate_workflow "$f" ;;
    # harness before *.sh — harness files match both; more-specific wins
    */bin/lib/harness/*.sh)      gate_harness  "$f" ;;
    *.sh)                        gate_shell    "$f" ;;
    *.jsonc)                     gate_jsonc    "$f" ;;
    *.jq)                        gate_jq       "$f" ;;
    *) return 0 ;;  # no gate for this file type
  esac
}

fail=0
for f in "$@"; do
  [ -f "$f" ] || continue
  case "$CLASS" in
    adr)      gate_adr      "$f" || fail=1 ;;
    skill)    gate_skill    "$f" || fail=1 ;;
    command)  gate_command  "$f" || fail=1 ;;
    workflow) gate_workflow "$f" || fail=1 ;;
    shell)    gate_shell    "$f" || fail=1 ;;
    jsonc)    gate_jsonc    "$f" || fail=1 ;;
    jq)       gate_jq       "$f" || fail=1 ;;
    harness)  gate_harness  "$f" || fail=1 ;;
    auto)     gate_auto     "$f" || fail=1 ;;
    *) echo "mentat-precommit: unknown class '$CLASS'" >&2; exit 1 ;;
  esac
done
exit "$fail"
