#!/usr/bin/env bash
# mentat-install — install mentat harness into ~/.agents/.
# Syncs vendored upstreams then rsyncs .agents/ to ~/.agents/.
# ADR 0004.
set -euo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
. "$HERE/lib/strict.sh"

FORCE_DIRTY=0
FORCE_GATE=0
YES=0
DRY_RUN=0
OFFLINE=0

for arg in "$@"; do
  case "$arg" in
    --force-dirty) FORCE_DIRTY=1 ;;
    --force-gate)  FORCE_GATE=1 ;;
    --yes)         YES=1 ;;
    --dry-run)     DRY_RUN=1 ;;
    --offline)     OFFLINE=1 ;;
    *)
      echo "usage: mentat-install [--force-dirty] [--force-gate] [--yes] [--dry-run] [--offline]" >&2
      echo "  --offline  skip upstream vendor sync (use existing vendir.lock.yml)" >&2
      exit 1 ;;
  esac
done

REPO_ROOT="$(cd "$HERE/../.." && pwd)"
AGENTS_DIR="$REPO_ROOT/.agents"

if [ ! -d "$AGENTS_DIR" ]; then
  echo "mentat-install: .agents/ not found at $AGENTS_DIR" >&2
  exit 1
fi

cd "$REPO_ROOT"

if [ "$FORCE_DIRTY" -eq 0 ]; then
  UNCOMMITTED=$(git -C "$REPO_ROOT" status --porcelain "$AGENTS_DIR" 2>/dev/null | { grep -c '^[MADRCU?]' || true; })
  if [ "$UNCOMMITTED" -gt 0 ]; then
    echo "mentat-install: $UNCOMMITTED uncommitted change(s) in .agents/ — commit first or use --force-dirty" >&2
    exit 1
  fi
fi

TRACKED_FILES=$(git -C "$REPO_ROOT" ls-files "$AGENTS_DIR" 2>/dev/null) || TRACKED_FILES=""
if [ -n "$TRACKED_FILES" ]; then
  GATE_FAIL=0
  # shellcheck source=/dev/null
  . "$HERE/lib/gates.sh"
  while IFS= read -r f; do
    [ -z "$f" ] && continue
    mentat_gate "$f" || GATE_FAIL=1
  done <<< "$TRACKED_FILES"
  if [ "$GATE_FAIL" -ne 0 ]; then
    echo "mentat-install: gate check failed — fix errors above before installing" >&2
    if [ "$FORCE_GATE" -eq 1 ]; then
      echo "mentat-install: WARNING: proceeding with --force-gate despite gate failure" >&2
    else
      exit 1
    fi
  fi
fi

# Sync vendored upstreams (unless --offline)
if [ "$OFFLINE" -eq 0 ]; then
  UPDATE_CMD="$HERE/mentat-update"
  if [ -x "$UPDATE_CMD" ]; then
    if [ "$DRY_RUN" -eq 1 ]; then
      echo "mentat-install: dry-run — would run: mentat-update"
    else
      echo "mentat-install: syncing vendored upstreams ..."
      if ! "$UPDATE_CMD"; then
        echo "mentat-install: WARNING: mentat-update failed (vendir not installed?). Skipping vendor sync." >&2
        echo "mentat-install: Install vendir: https://carvel.dev/vendir/docs/latest/install/" >&2
        echo "mentat-install: Re-run without --offline after installing vendir, or run: mentat-update" >&2
      fi
    fi
  fi
fi

RSYNC_ARGS=(-av --delete -L
  --exclude='evals/'
  --exclude='.dmux-hooks/'
  --exclude='vendored/'
  --exclude='*.bak.*'
  --exclude='.DS_Store'
  --exclude='bin/mentat-credits-gen'
  --exclude='bin/mentat-release'
  --exclude='bin/mentat-install'
  --exclude='bin/mentat-update'
  --exclude='upstreams.jsonc'
  --exclude='upstreams.lock.jsonc'
  --exclude='.skill-lock.json'
  --exclude='plans/'
  --exclude='mentat/'
)

if [ "$DRY_RUN" -eq 1 ]; then
  RSYNC_ARGS+=(-n)
  echo "mentat-install: dry-run — no files will be written"
fi

if [ "$DRY_RUN" -eq 0 ] && [ "$YES" -eq 0 ]; then
  DELETE_LIST=$(rsync "${RSYNC_ARGS[@]}" -n "$AGENTS_DIR/" "$HOME/.agents/" 2>/dev/null \
    | grep '^deleting ' || true)
  if [ -n "$DELETE_LIST" ]; then
    echo "mentat-install: files to delete from ~/.agents/:"
    echo "$DELETE_LIST"
    printf 'Proceed? [y/N] '
    read -r reply </dev/tty || reply=""
    case "$reply" in
      [Yy]*) ;;
      *) echo "mentat-install: aborted"; exit 1 ;;
    esac
  fi
fi

rsync "${RSYNC_ARGS[@]}" "$AGENTS_DIR/" "$HOME/.agents/"
echo "mentat-install: done"
