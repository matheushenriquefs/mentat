#!/bin/bash
# mentat-container-doctor — diagnose container state for the current worktree.
# Reports each invariant (host deps + lib state) as OK/FAIL, naming the exact
# missing path on FAIL so the user knows what to repair. ADR 0004.
#
# Lib predicates (slug, CID, workspaceFolder, safe.directory) flow through
# lib/container-state.sh — see .agents/docs/container-state-design.md.
set -euo pipefail

# shellcheck source=/dev/null
. "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/lib/strict.sh"
# shellcheck source=/dev/null
. "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/lib/container-state.sh"

RC=0

ok()   { echo "OK  $1"; }
fail() { echo "FAIL $1"; RC=1; }

check() {
  local label="$1" cmd="$2"
  if eval "$cmd" >/dev/null 2>&1; then
    ok "$label"
  else
    fail "$label"
  fi
}

# Host preconditions.
check "git"           "command -v git"
check "jq"            "command -v jq"
check "docker socket" "test -S /var/run/docker.sock"

# Container state via lib (only meaningful inside a worktree).
if [ -f "$PWD/.git" ]; then
  SLUG="$(container_slug_for_cwd)"
  WS="/workspaces/$SLUG"

  if CID="$(container_id_for "$SLUG" 2>/dev/null)"; then
    ok "container running ($CID) for slug=$SLUG"

    if msg="$(ensure_workspace_folder "$WS" 2>&1)"; then
      ok "workspaceFolder $WS"
    else
      fail "$msg"
    fi

    if msg="$(assert_safe_directory "$WS" 2>&1)"; then
      ok "safe.directory $WS"
    else
      fail "$msg"
    fi
  else
    fail "container not running for slug=$SLUG (run mentat-container-up)"
  fi
fi

exit "$RC"
