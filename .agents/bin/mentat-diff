#!/usr/bin/env bash
# mentat-diff — emit cumulative diff of holding branch vs main (or fork point)
# Usage: mentat-diff [--stat-only] [--name-only] [--since=<sha>] [<holding-branch>]
# ADR 0002 ADR 0004
set -euo pipefail

_LIB="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/lib"
. "$_LIB/strict.sh"
. "$_LIB/log.sh"
. "$_LIB/audit.sh"
_LOG_PREFIX=mentat-diff

STAT_ONLY=0
NAME_ONLY=0
SINCE=""
BRANCH=""

while [ "$#" -gt 0 ]; do
  case "$1" in
    --stat-only)  STAT_ONLY=1; shift ;;
    --name-only)  NAME_ONLY=1; shift ;;
    --since=*)    SINCE="${1#*=}"; shift ;;
    --) shift; break ;;
    -*) die "unknown flag: $1" ;;
    *)  BRANCH="$1"; shift ;;
  esac
done

# Resolve holding branch: arg > git symbolic-ref > error
if [ -z "$BRANCH" ]; then
  BRANCH="$(git symbolic-ref --short HEAD 2>/dev/null)" \
    || die "cannot resolve holding branch — pass it as argument"
fi

git rev-parse --verify "$BRANCH" >/dev/null 2>&1 \
  || die "branch not found: $BRANCH"

# Base: --since sha or merge-base against main
if [ -n "$SINCE" ]; then
  git rev-parse --verify "$SINCE" >/dev/null 2>&1 \
    || die "sha not found: $SINCE"
  BASE="$SINCE"
else
  BASE="$(git merge-base main "$BRANCH")" \
    || die "cannot compute merge-base (is 'main' reachable?)"
fi

TIP="$(git rev-parse "$BRANCH")"
FILES="$(git diff --name-only "$BASE" "$TIP" | wc -l | tr -d ' ')"

mentat_audit mentat-diff diff.emit "$(jq -cn \
  --arg base  "$BASE" \
  --arg tip   "$TIP" \
  --arg branch "$BRANCH" \
  --argjson files "$FILES" \
  '{base:$base, tip:$tip, branch:$branch, files:$files}')"

echo "--- mentat-diff ---"
echo "branch : $BRANCH"
echo "base   : $BASE"
echo "tip    : $TIP"
echo "files  : $FILES"
echo ""

if [ "$NAME_ONLY" -eq 1 ]; then
  rtk git diff "$BASE".."$TIP" --name-only
elif [ "$STAT_ONLY" -eq 1 ]; then
  rtk git diff "$BASE".."$TIP" --stat
else
  rtk git diff "$BASE".."$TIP" --stat
  echo ""
  rtk git diff "$BASE".."$TIP"
fi
