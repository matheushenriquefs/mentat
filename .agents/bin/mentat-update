#!/usr/bin/env bash
# mentat-update — sync vendored upstreams via vendir, then regenerate CREDITS.md.
# Usage: mentat-update [--offline]
#   no args   sync all upstreams (vendir sync)
#   --offline skip sync if vendir.lock.yml present; regenerate credits only
set -euo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$HERE/../.." && pwd)"
# shellcheck source=/dev/null
. "$HERE/lib/audit.sh"
LOCK="$REPO_ROOT/vendir.lock.yml"
VENDIR_YML="$REPO_ROOT/vendir.yml"
CREDITS="$REPO_ROOT/CREDITS.md"

OFFLINE=0
for arg in "$@"; do
  case "$arg" in
    --offline) OFFLINE=1 ;;
    *) echo "usage: mentat-update [--offline]" >&2; exit 1 ;;
  esac
done

if [ ! -f "$VENDIR_YML" ]; then
  echo "mentat-update: vendir.yml not found at $VENDIR_YML" >&2
  exit 1
fi

# Sync
if [ "$OFFLINE" -eq 1 ]; then
  if [ ! -f "$LOCK" ]; then
    echo "mentat-update: --offline but no vendir.lock.yml found; run without --offline first" >&2
    exit 1
  fi
  echo "mentat-update: offline mode — skipping sync"
else
  if ! command -v vendir &>/dev/null; then
    echo "mentat-update: vendir not found on PATH. Install: https://carvel.dev/vendir/docs/latest/install/" >&2
    exit 1
  fi
  echo "mentat-update: running vendir sync ..."
  cd "$REPO_ROOT"
  vendir sync
  echo "mentat-update: sync complete"
  mentat_audit mentat-update sync.complete "$(jq -cn \
    --arg vendir_yml "$VENDIR_YML" \
    '{upstreams:[$vendir_yml], changed:-1}')"
fi

# Regenerate CREDITS.md from vendir.lock.yml
if [ ! -f "$LOCK" ]; then
  echo "mentat-update: no vendir.lock.yml; skipping credits regen" >&2
  exit 0
fi

if ! command -v yq &>/dev/null; then
  echo "mentat-update: yq not found — skipping CREDITS.md regen (install: https://github.com/mikefarah/yq)" >&2
  exit 0
fi

echo "mentat-update: regenerating CREDITS.md ..."

_gh_description() {
  local repo="$1"
  local desc=""
  if command -v gh &>/dev/null; then
    desc=$(gh repo view "$repo" --json description -q .description 2>/dev/null || true)
  fi
  if [ -z "$desc" ]; then
    desc=$(curl -fsSL "https://api.github.com/repos/$repo" 2>/dev/null | jq -r '.description // empty' 2>/dev/null || true)
  fi
  echo "${desc:-(no upstream description)}"
}

# Build vendored table rows from lock file
rows=""
dir_count=$(yq '.directories | length' "$LOCK")
for i in $(seq 0 $((dir_count - 1))); do
  content_count=$(yq ".directories[$i].contents | length" "$LOCK")
  for j in $(seq 0 $((content_count - 1))); do
    path=$(yq ".directories[$i].contents[$j].path" "$LOCK")
    url=$(yq ".directories[$i].contents[$j].git.url" "$LOCK" 2>/dev/null || echo "")
    sha=$(yq ".directories[$i].contents[$j].git.sha" "$LOCK" 2>/dev/null || echo "HEAD")
    tags=$(yq ".directories[$i].contents[$j].git.tags // [] | join(\", \")" "$LOCK" 2>/dev/null || echo "")
    if [ -z "$url" ]; then continue; fi
    repo="${path}"
    desc=$(_gh_description "$repo")
    pin_display="${tags:-${sha:0:12}}"
    rows="${rows}| ${repo} | ${url} | \`${pin_display}\` | ${desc} |"$'\n'
  done
done

cat > "$CREDITS.tmp" <<EOF
<!-- AUTO-GENERATED by bin/mentat-update — do not edit header or Vendored section -->
# Credits

## Vendored

Upstreams managed by [vendir](https://carvel.dev/vendir/). Regenerate: \`bin/mentat-update\`.

| Name | URL | Pin | Description |
|------|-----|-----|-------------|
${rows}
## Inspired by

- **[mattpocock/skills](https://github.com/mattpocock/skills)** — Engineering and productivity skills for Claude Code. Backbone of \`mentat-tasks\`: to-issues template, voice, LOC discipline, HITL/AFK classification, and vertical-slice doctrine.
- **[antopolskiy/kanban-md](https://github.com/antopolskiy/kanban-md)** — (no upstream description). Flavor of \`mentat-tasks\`: \`allowed-tools:\` frontmatter whitelist, atomic \`pick --claim\` + \`claim_timeout\` refresh, \`review\`-as-waiting-room status, board-home/worktree separation.
- **[Purple-Horizons/tick-md](https://github.com/Purple-Horizons/tick-md)** — (no upstream description). Reference for dep-graph + auto-unblock + filename convention. Acknowledged, not adopted; revisit when real pain hits.

## Runtime tool dependencies

| Tool | URL | License | Used for |
|------|-----|---------|---------|
| vendir | https://github.com/carvel-dev/vendir | Apache-2.0 | Declarative vendoring (S3) |
| lefthook | https://github.com/evilmartians/lefthook | MIT | Pre-commit quality gates |
| yq | https://github.com/mikefarah/yq | MIT | Task md frontmatter mutation (S10) |
| jq | https://github.com/jqlang/jq | MIT | Bash+jq pipelines across bin/ |
EOF

mv "$CREDITS.tmp" "$CREDITS"
echo "mentat-update: CREDITS.md updated"
