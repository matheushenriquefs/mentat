#!/usr/bin/env bash
# mentat-track — colored slug-prefixed feed over per-chunk stream-json tees.
# Sourced by mentat-orchestrate; also runnable standalone.
# Usage (standalone): mentat-track <logdir> <slug>...
# Exported fns (sourced): to_track_start / to_track_phase / to_track_exit / to_track_stop
set -uo pipefail

_LIB="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/lib"
. "$_LIB/strict.sh"

JQ="${JQ:-jq}"
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
MAP="${TO_TRACK_MAP:-$HERE/harness-map.jq}"
THINK="${TO_TRACK_THINK:-0}"

if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
  c_dim=$'\e[2m'; c_rst=$'\e[0m'; c_bold=$'\e[1m'
  c_blue=$'\e[34m'; c_cyan=$'\e[36m'; c_green=$'\e[32m'
  c_yellow=$'\e[33m'; c_red=$'\e[31m'; c_mag=$'\e[35m'
else
  c_dim=; c_rst=; c_bold=; c_blue=; c_cyan=; c_green=; c_yellow=; c_red=; c_mag=
fi

_slug_color() {
  local h=0 i; for ((i=0;i<${#1};i++)); do h=$(( (h*31 + $(printf '%d' "'${1:$i:1}")) % 6 )); done
  case $h in 0)echo "$c_blue";;1)echo "$c_cyan";;2)echo "$c_mag";;
             3)echo "$c_green";;4)echo "$c_yellow";;*)echo "$c_bold";;esac
}

_paint() { # $1=kind $2=summary
  local g col
  case "$1" in
    init)   g="◆"; col="$c_dim";;
    text)   g="·"; col="$c_rst";;
    tool)   g="⚙"; col="$c_cyan";;
    think)  g="∴"; col="$c_dim";;
    info)   g="↻"; col="$c_yellow";;
    result) g="✓"; col="$c_green";;
    error)  g="✗"; col="$c_red";;
    raw)    g="?"; col="$c_dim";;
    *)      g="·"; col="$c_rst";;
  esac
  printf '%s%s %s%s' "$col" "$g" "$2" "$c_rst"
}

_feed() { # $1=slug $2=logfile
  local slug="$1" log="$2" scol; scol="$(_slug_color "$slug")"
  local tag; printf -v tag '%s%-10s%s' "$scol" "[$slug]" "$c_rst"
  tail -n +1 -F "$log" 2>/dev/null \
  | "$JQ" -rc -f "$MAP" 2>/dev/null \
  | while IFS=$'\t' read -r kind summary; do
      [[ "$kind" == "think" && "$THINK" != "1" ]] && continue
      printf '%s %s\n' "$tag" "$(_paint "$kind" "$summary")"
    done
}

_banner() { # $1=slug $2=glyph $3=color $4=label [$5=note]
  local scol; scol="$(_slug_color "$1")"
  printf '%s%-10s%s %s%s %s%s%s' "$scol" "[$1]" "$c_rst" "$3" "$2" "$c_bold" "$4" "$c_rst"
  [[ -n "${5:-}" ]] && printf ' %s%s%s' "$c_dim" "$5" "$c_rst"
  printf '\n'
}

to_track_phase() { # slug implementing|landing
  case "$2" in
    implementing) _banner "$1" "⛏" "$c_blue"   "implementing";;
    landing)      _banner "$1" "↧" "$c_yellow" "landing";;
    *)            _banner "$1" "·"  "$c_dim"    "$2";;
  esac
}

to_track_exit() { # slug landed|forensics|agent-error [note]
  case "$2" in
    landed)      _banner "$1" "✓" "$c_green"  "landed"      "${3:-}";;
    forensics)   _banner "$1" "✗" "$c_red"    "left up — forensics" "${3:-}";;
    agent-error) _banner "$1" "✗" "$c_red"    "agent error" "${3:-}";;
    *)           _banner "$1" "·" "$c_dim"    "$2"          "${3:-}";;
  esac
}

_pids=()
to_track_start() { # logdir slug...
  local logdir="$1"; shift
  local slug
  for slug in "$@"; do
    to_track_phase "$slug" implementing
    _feed "$slug" "$logdir/$slug.jsonl" &
    _pids+=("$!")
  done
}
to_track_stop() { local p; for p in "${_pids[@]:-}"; do kill "$p" 2>/dev/null || true; done; }

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  if [ "$#" -eq 0 ]; then
    LOG_ROOT="${MENTAT_LOG_DIR:-$HOME/.agents/mentat/logs}"
    REPO="$(basename "$PWD")"
    [ -d "$LOG_ROOT/$REPO" ] || { echo "mentat-track: no log dir for repo '$REPO' at $LOG_ROOT/$REPO" >&2; exit 1; }
    SESS="$(find "$LOG_ROOT/$REPO" -mindepth 1 -maxdepth 1 -type d | sort -r | head -1 | xargs basename 2>/dev/null || true)"
    [ -n "$SESS" ] || { echo "mentat-track: no sessions under $LOG_ROOT/$REPO" >&2; exit 1; }
    shopt -s nullglob
    SLUG_LOGS=("$LOG_ROOT/$REPO/$SESS"/mentat-*.jsonl)
    [ "${#SLUG_LOGS[@]}" -gt 0 ] || { echo "mentat-track: no slug logs in $LOG_ROOT/$REPO/$SESS" >&2; exit 1; }
    SLUGS_ONLY=()
    for _sf in "${SLUG_LOGS[@]}"; do
      _base="$(basename "$_sf" .jsonl)"
      SLUGS_ONLY+=("$_base")
    done
    set -- "$LOG_ROOT/$REPO/$SESS" "${SLUGS_ONLY[@]}"
  fi
  [[ $# -lt 2 ]] && { echo "usage: mentat-track <logdir> <slug>..." >&2; exit 2; }
  trap to_track_stop EXIT INT TERM
  to_track_start "$@"
  wait
fi
