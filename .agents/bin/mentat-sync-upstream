#!/usr/bin/env bash
# mentat-sync-upstream — clone upstream at pin, rsync into vendor/<user>/<repo>/, write lockfile.
# Usage: mentat-sync-upstream <user>/<repo>
#        mentat-sync-upstream --all           (sync all upstreams)
#        mentat-sync-upstream --print-credits (emit CREDITS.md from upstreams.jsonc)
set -euo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$HERE/../.." && pwd)"
MANIFEST="$REPO_ROOT/upstreams.jsonc"
LOCKFILE="$REPO_ROOT/upstreams.lock.jsonc"

if [ ! -f "$MANIFEST" ]; then
  echo "mentat-sync-upstream: upstreams.jsonc not found at $MANIFEST" >&2
  exit 1
fi

_parse_manifest() {
  sed '/^[[:space:]]*\/\//d' "$MANIFEST"
}

_parse_lock() {
  [ -f "$LOCKFILE" ] && sed '/^[[:space:]]*\/\//d' "$LOCKFILE" || echo '{"upstreams":{}}'
}

_print_credits() {
  echo "# Credits"
  echo ""
  echo "Vendored upstream dependencies used in this project."
  echo ""
  echo "| Upstream | URL | License | Pin | Description |"
  echo "|----------|-----|---------|-----|-------------|"

  _parse_manifest | jq -r '.upstreams | to_entries[] |
    "| " + .key +
    " | " + .value.url +
    " | " + (.value.license // "unknown") +
    " | `" + (.value.pin // "HEAD") + "`" +
    " | " + (.value.description // "") +
    " |"'

  echo ""
  echo "## Notices"
  echo ""

  _parse_manifest | jq -r '.upstreams | to_entries[] | .key' | while IFS= read -r key; do
    local vendor_dir="$REPO_ROOT/.agents/skills/vendor/$key"
    local notice="$vendor_dir/NOTICE"
    if [ -f "$notice" ]; then
      echo "### $key"
      echo ""
      cat "$notice"
      echo ""
    fi
  done

  echo "_Generated by \`bin/mentat-sync-upstream --print-credits\`. Edit \`upstreams.jsonc\`, not this file._"
}

_write_lockfile_entry() {
  local key="$1" ref_type="$2" ref="$3" sha="$4"
  local ts; ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

  local current; current="$(_parse_lock)"
  local updated
  updated=$(echo "$current" | jq --arg k "$key" --arg rt "$ref_type" --arg r "$ref" \
    --arg s "$sha" --arg ts "$ts" \
    '.upstreams[$k] = {ref_type:$rt, ref:$r, sha:$s, fetched_at:$ts}')
  printf '%s\n' "$updated" > "$LOCKFILE"
}

_sync_one() {
  local key="$1"

  local upstream_json
  upstream_json=$(_parse_manifest | jq -e --arg k "$key" '.upstreams[$k] // empty') || {
    echo "mentat-sync-upstream: upstream '$key' not found in upstreams.jsonc" >&2
    exit 1
  }

  local url pin subpath
  url=$(echo "$upstream_json" | jq -r '.url')
  pin=$(echo "$upstream_json" | jq -r '.pin // "HEAD"')
  subpath=$(echo "$upstream_json" | jq -r '.subpath // "."')

  local vendor_rel=".agents/skills/vendor/$key"
  local full_vendor="$REPO_ROOT/$vendor_rel"

  local normalized
  normalized="$(python3 -c "import os,sys; print(os.path.normpath(os.path.join('$REPO_ROOT', sys.argv[1])))" "$vendor_rel" 2>/dev/null \
    || echo "$REPO_ROOT/$vendor_rel")"
  if [[ "$normalized" != "$REPO_ROOT"/* ]]; then
    echo "mentat-sync-upstream: vendor path '$vendor_rel' escapes repo root — refusing" >&2
    exit 1
  fi

  local ref_type="tag"
  if echo "$pin" | grep -qE '^[0-9a-f]{12,40}$'; then
    ref_type="sha"
  fi

  local tmpdir; tmpdir=$(mktemp -d)
  # Use subshell so cleanup is scoped to this invocation; EXIT trap doesn't leak across --all iterations.
  (
  trap 'rm -rf "$tmpdir"' EXIT

  echo "mentat-sync-upstream: cloning $key at $pin ..."
  git clone --depth=1 "$url" "$tmpdir/repo" 2>/dev/null

  if [ "$pin" != "HEAD" ]; then
    git -C "$tmpdir/repo" fetch --depth=1 origin "$pin" 2>/dev/null || true
    if ! git -C "$tmpdir/repo" checkout "$pin" 2>/dev/null; then
      local actual; actual=$(git -C "$tmpdir/repo" rev-parse HEAD)
      echo "mentat-sync-upstream: WARNING: could not checkout pin '$pin'; at $actual" >&2
      echo "mentat-sync-upstream: verify pin is a reachable ref — aborting" >&2
      exit 1
    fi
  fi

  local actual_sha; actual_sha=$(git -C "$tmpdir/repo" rev-parse HEAD)

  local src="$tmpdir/repo"
  if [ "$subpath" != "." ]; then
    src="$tmpdir/repo/$subpath"
  fi

  if [ ! -d "$src" ]; then
    echo "mentat-sync-upstream: subpath '$subpath' not found in cloned repo" >&2
    exit 1
  fi

  mkdir -p "$full_vendor"
  echo "mentat-sync-upstream: syncing into $vendor_rel ..."
  rsync -av --delete "$src/" "$full_vendor/"

  for f in LICENSE NOTICE; do
    [ -f "$tmpdir/repo/$f" ] && cp "$tmpdir/repo/$f" "$full_vendor/$f" || true
  done

  _write_lockfile_entry "$key" "$ref_type" "$pin" "${actual_sha:0:12}"

  local sync_log="${MENTAT_SYNC_LOG:-$HOME/.agents/mentat/logs/sync-upstream.jsonl}"
  mkdir -p "$(dirname "$sync_log")"
  jq -cn --arg upstream "$key" --arg sha "${actual_sha:0:12}" \
    '{ts:(now|todate), upstream:$upstream, sha:$sha, status:"ok"}' >> "$sync_log"

  local credits_gen="$HERE/mentat-credits-gen"
  if [ -x "$credits_gen" ]; then
    "$credits_gen" > /dev/null
    echo "mentat-sync-upstream: regenerated CREDITS.md"
  fi

  echo "mentat-sync-upstream: done — $key @ ${actual_sha:0:12}"
  ) # end subshell — EXIT trap is scoped, tmpdir always cleaned
}

if [ "${1:-}" = "--print-credits" ]; then
  _print_credits
  exit 0
fi

if [ "${1:-}" = "--all" ]; then
  _parse_manifest | jq -r '.upstreams | keys[]' | while IFS= read -r key; do
    _sync_one "$key"
  done
  exit 0
fi

KEY="${1:-}"
if [ -z "$KEY" ]; then
  echo "usage: mentat-sync-upstream <user>/<repo> | --all | --print-credits" >&2
  exit 1
fi

_sync_one "$KEY"
