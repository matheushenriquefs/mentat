#!/usr/bin/env bash
# mentat-credits-gen — regenerate CREDITS.md from upstreams.jsonc. Idempotent.
set -euo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$HERE/../.." && pwd)"
MANIFEST="$REPO_ROOT/upstreams.jsonc"
CREDITS="$REPO_ROOT/CREDITS.md"

if [ ! -f "$MANIFEST" ]; then
  echo "mentat-credits-gen: upstreams.jsonc not found at $MANIFEST" >&2
  exit 1
fi

_parse() {
  sed '/^[[:space:]]*\/\//d' "$MANIFEST"
}

{
  echo "<!-- AUTO-GENERATED by bin/mentat-credits-gen — do not edit -->"
  echo "# Credits"
  echo ""
  echo "Vendored upstream dependencies."
  echo ""
  echo "| Name | URL | License | Pin | Description |"
  echo "|------|-----|---------|-----|-------------|"
  _parse | jq -r '.upstreams[] |
    "| " + .name +
    " | " + .url +
    " | " + (.license // "unknown") +
    " | `" + (.pin // "HEAD") + "`" +
    " | " + (.description // "") +
    " |"'
  echo ""
  echo "_Regenerate: \`bin/mentat-credits-gen\`. Edit \`upstreams.jsonc\`, not this file._"
} > "$CREDITS"

cat "$CREDITS"
