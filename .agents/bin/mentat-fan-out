#!/bin/bash
# mentat-fan-out — spawn parallel chunk implementations. ADR-0011.
#
# Stdin:  newline-delim slice plan paths.
# Stdout: newline-delim chunk slugs (impl-OK chunks only).
# Side:   one worktree + devcontainer per path. Emits chunk.spawn per spawn.
#         Failed implements emit land.complete reason=implement-fail and are
#         omitted from stdout (caller can't land them).
# Exit:   0 = every chunk impl-OK; 1 = partial (>=1 impl-fail);
#         >=2 = tool-level error (bad argv, missing config, oversized batch).
set -euo pipefail

_LIB="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/lib"
. "$_LIB/strict.sh"
. "$_LIB/log.sh"
. "$_LIB/here.sh"
. "$_LIB/config.sh"
. "$_LIB/audit.sh"
_LOG_PREFIX=mentat-fan-out

# Override log.sh::die to exit 2 — ADR-0011 exit-code contract: 1=partial, >=2=tool-level.
die() { printf '[%s] ERROR %s\n' "$_LOG_PREFIX" "$*" >&2; exit 2; }

HARNESS="$(mentat_config harness.name)"; HARNESS="${HARNESS:-cursor}"
MODEL="$(mentat_config harness.model)"; MODEL="${MODEL:-}"
PARALLEL_CAP="$(mentat_config agents.max_concurrent)"; PARALLEL_CAP="${PARALLEL_CAP:-3}"

while [ "$#" -gt 0 ]; do
  case "$1" in
    --harness=*) HARNESS="${1#*=}"; shift ;;
    --model=*)   MODEL="${1#*=}";   shift ;;
    --) shift; break ;;
    -*) die "unknown flag $1 (usage: mentat-fan-out [--harness=<name>] [--model=<slug>])" ;;
    *)  break ;;
  esac
done

mentat_config_validate >&2 || die "invalid .mentat.jsonc — fix config before running"
PARALLEL_CAP="$(mentat_config agents.max_concurrent)"; PARALLEL_CAP="${PARALLEL_CAP:-3}"

declare -a PLANS=()
while IFS= read -r _line; do
  [ -z "$_line" ] && continue
  PLANS+=("$_line")
done

if [ "${#PLANS[@]}" -eq 0 ]; then
  log "empty stdin — zero chunks spawned"
  exit 0
fi

[ "${#PLANS[@]}" -le "$PARALLEL_CAP" ] || die "max $PARALLEL_CAP parallel chunks (merge-conflict scaling — ADR 0004)"

ROOT="$PWD"
: "${MENTAT_REPO:=$(basename "$ROOT")}"
: "${MENTAT_SESSION:=$(date +%s)-$$}"
export MENTAT_REPO MENTAT_SESSION
LOGDIR="${MENTAT_LOG_PATH:-$HOME/.agents/mentat/logs}/$MENTAT_REPO/$MENTAT_SESSION"
mkdir -p "$LOGDIR"

build_cmd() {
  local prompt="$1"
  local hfile="$_LIB/harness/${HARNESS}.sh"
  [ -f "$hfile" ] || die "unknown harness '$HARNESS' — no $hfile"
  . "$hfile"
  "harness_${HARNESS//-/_}_cmd" "$prompt"
}

_chunk_spawn_emit() { # $1=slug $2=plan
  MENTAT_SLUG="$1" mentat_audit mentat-orchestrate chunk.spawn "$(jq -cn \
    --arg slug "$1" --arg plan "$2" '{slug:$slug, plan:$plan}')"
}

_impl_fail_emit() { # $1=slug
  MENTAT_SLUG="$1" mentat_audit mentat-orchestrate land.complete "$(jq -cn \
    --arg slug "$1" \
    '{slug:$slug, outcome:"eject", tip:"", reason:"implement-fail"}')"
}

run_chunk() { # $1=plan $2=slug $3=logf
  local plan="$1" slug="$2" logf="$3"
  local wt="$ROOT/.mentat/worktrees/$slug"
  git worktree add -b "$slug" "$wt" main >&2
  export MENTAT_WORKTREE_PATH="$wt"
  ( cd "$wt" && ~/.agents/bin/mentat-container-up >&2 )
  local cmd=()
  while IFS= read -r -d '' tok; do cmd+=("$tok"); done < <(build_cmd "/mentat-implement $plan")
  local hfile="$_LIB/harness/${HARNESS}.sh"
  . "$hfile"
  local norm_fn="harness_${HARNESS//-/_}_normalize"
  local stdout_f="${logf%.jsonl}.stdout"
  export -f "$norm_fn" 2>/dev/null || true
  ( cd "$wt" && "${cmd[@]}" </dev/null ) 2>&1 \
    | tee "$stdout_f" \
    | bash -c "source $(printf %q "$hfile") && $norm_fn" \
    >> "$logf"
}

declare -a PIDS=() SLUGS=() LOGS=()
for plan in "${PLANS[@]}"; do
  [ -f "$plan" ] || die "plan not found: $plan"
  slug="mentat-$(date +%s)-$$-$RANDOM"
  logf="$LOGDIR/$slug.jsonl"
  : > "$logf"
  SLUGS+=("$slug"); LOGS+=("$logf")
  _chunk_spawn_emit "$slug" "$plan"
  log "chunk: $plan -> $slug | $logf"
done

for i in "${!SLUGS[@]}"; do
  run_chunk "${PLANS[$i]}" "${SLUGS[$i]}" "${LOGS[$i]}" & PIDS+=("$!")
done

PARTIAL=0
for i in "${!PIDS[@]}"; do
  if wait "${PIDS[$i]}"; then
    printf '%s\n' "${SLUGS[$i]}"
  else
    _impl_fail_emit "${SLUGS[$i]}"
    log "CHUNK FAILED (implement): ${PLANS[$i]} — worktree $ROOT/.mentat/worktrees/${SLUGS[$i]}"
    PARTIAL=1
  fi
done

exit "$PARTIAL"
