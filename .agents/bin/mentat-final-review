#!/bin/bash
# mentat-final-review — end-of-queue ADR-0003 reviewer pass. ADR-0011.
#
# Argv:   <base-sha> <tip-sha>                (two positional, explicit)
# Stdin:  nothing.
# Stdout: single JSONL verdict line:
#           {reviewer, score, veto, findings, base, tip, stdout?, stderr_path?}
# Side:   spawn cavecrew-orchestrated ADR-0003 reviewer set against
#         (base..tip). Subprocess stdout captured (tail -c 4000) into audit
#         `stdout` field. Subprocess stderr tee'd to sidecar at
#         $LOGDIR/.stderr/mentat-final-review.stderr — never in `.jsonl`.
#         Emits one `review.final` audit row. Review is advisory — never
#         rolls back the landed ref.
# Exit:   0 = tool ran (review verdict on stdout, veto bit may be true);
#         >=2 = tool-level failure (bad argv, missing config, container-up
#               failed at $ROOT).
set -euo pipefail

_LIB="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/lib"
. "$_LIB/strict.sh"
. "$_LIB/log.sh"
. "$_LIB/here.sh"
. "$_LIB/config.sh"
. "$_LIB/audit.sh"
_LOG_PREFIX=mentat-final-review

# Override log.sh::die to exit 2 — ADR-0011: >=2 = tool-level failure.
die() { printf '[%s] ERROR %s\n' "$_LOG_PREFIX" "$*" >&2; exit 2; }

HARNESS="$(mentat_config harness.name)"; HARNESS="${HARNESS:-cursor}"
MODEL="$(mentat_config harness.model)"; MODEL="${MODEL:-}"

while [ "$#" -gt 0 ]; do
  case "$1" in
    --harness=*) HARNESS="${1#*=}"; shift ;;
    --model=*)   MODEL="${1#*=}";   shift ;;
    --) shift; break ;;
    -*) die "unknown flag $1 (usage: mentat-final-review [--harness=<n>] [--model=<s>] <base-sha> <tip-sha>)" ;;
    *)  break ;;
  esac
done

BASE="${1:-}"
TIP="${2:-}"
[ -n "$BASE" ] || die "missing positional <base-sha> (usage: mentat-final-review <base-sha> <tip-sha>)"
[ -n "$TIP" ]  || die "missing positional <tip-sha> (usage: mentat-final-review <base-sha> <tip-sha>)"
shift 2 || true

mentat_config_validate >&2 || die "invalid .mentat.jsonc — fix config before running"

ROOT="$PWD"
: "${MENTAT_REPO:=$(basename "$ROOT")}"
: "${MENTAT_SESSION:=$(date +%s)-$$}"
export MENTAT_REPO MENTAT_SESSION
LOGDIR="${MENTAT_LOG_PATH:-$HOME/.agents/mentat/logs}/$MENTAT_REPO/$MENTAT_SESSION"
mkdir -p "$LOGDIR"

build_cmd() {
  local prompt="$1"
  local hfile="$_LIB/harness/${HARNESS}.sh"
  [ -f "$hfile" ] || die "unknown harness '$HARNESS' — no $hfile"
  . "$hfile"
  "harness_${HARNESS//-/_}_cmd" "$prompt"
}

# Subprocess stdout captured for audit field; stderr -> sidecar (ADR 0009).
stderr_dir="$LOGDIR/.stderr"
stderr_path="$stderr_dir/mentat-final-review.stderr"
mkdir -p "$stderr_dir"
log "end-of-queue review: spawning ADR-0003 reviewers over $BASE..$TIP"

# Ensure container is up at $ROOT — failure is tool-level (exit >=2) here.
if ! up_out="$( cd "$ROOT" && ~/.agents/bin/mentat-container-up 2>&1 )"; then
  printf '%s\n' "$up_out" >> "$stderr_path"
  die "mentat-container-up failed at $ROOT (see $stderr_path)"
fi

prompt="The merge queue landed every chunk onto $TIP. Run the full ADR-0003 \
review gate over the cumulative diff $BASE..$TIP: spawn mentat-plan-reviewer, \
mentat-test-reviewer, mentat-bug-reviewer, and mentat-smell-reviewer (advisory, \
threshold 0.85, no max-sev veto), apply the gate (never average, veto > \
threshold), and report each score + the verdict. Read CLAUDE.md/AGENTS.md for how \
this project runs its checks. Do not modify code."
rcmd=()
while IFS= read -r -d '' tok; do rcmd+=("$tok"); done < <(build_cmd "$prompt")

# Capture stdout for the audit field; redirect stderr straight to the
# sidecar so it never lands in the .jsonl stream.
verdict="success"; rc=0
stdout_capture="$( cd "$ROOT" && "${rcmd[@]}" 2>>"$stderr_path" )" || rc=$?
if [ "$rc" -ne 0 ]; then
  verdict="flagged"
  log "end-of-queue review FLAGGED a miss (sidecar $stderr_path). Landed ref unchanged (advisory)."
else
  log "end-of-queue review done (sidecar $stderr_path)"
fi

# Trim captured stdout so a chatty agent can't bloat the audit row.
stdout_field="$(printf '%s' "$stdout_capture" | tail -c 4000)"
veto_bool="false"; [ "$verdict" = flagged ] && veto_bool="true"
score="$([ "$verdict" = success ] && echo 1.0 || echo 0.0)"

# Audit row — review.final (schema: required reviewer/score/veto/findings).
mentat_audit mentat-final-review review.final "$(jq -cn \
  --arg reviewer "adr-0003-composite" \
  --argjson score "$score" \
  --argjson veto "$veto_bool" \
  --arg base "$BASE" --arg tip "$TIP" \
  --arg stdout "$stdout_field" \
  --arg stderr_path "$stderr_path" \
  '{reviewer:$reviewer, score:$score, veto:$veto, findings:[], base:$base, tip:$tip, stdout:$stdout, stderr_path:$stderr_path}')"

# JSONL verdict on stdout — single line, mirrors the audit payload.
jq -cn \
  --arg reviewer "adr-0003-composite" \
  --argjson score "$score" \
  --argjson veto "$veto_bool" \
  --arg base "$BASE" --arg tip "$TIP" \
  --arg stdout "$stdout_field" \
  --arg stderr_path "$stderr_path" \
  '{reviewer:$reviewer, score:$score, veto:$veto, findings:[], base:$base, tip:$tip, stdout:$stdout, stderr_path:$stderr_path}'

# Advisory: review never rolls back. Tool exit code is 0 regardless of veto bit.
exit 0
