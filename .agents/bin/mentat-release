#!/usr/bin/env bash
# mentat-release — git release management (tag, status).
# For consumer harness install, use mentat-install.
set -euo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$HERE/../.." && pwd)"

TAG=""
DRY_RUN=0

for arg in "$@"; do
  case "$arg" in
    --tag=*) TAG="${arg#--tag=}" ;;
    --dry-run) DRY_RUN=1 ;;
    --help|-h)
      echo "usage: mentat-release [--tag=<v>] [--dry-run]"
      echo ""
      echo "No args: show release status (last tag, commits since)."
      echo "--tag=<v>: create and push git tag <v>."
      echo ""
      echo "For harness install: use mentat-install instead."
      exit 0 ;;
    *)
      echo "mentat-release: unknown arg '$arg'" >&2
      echo "usage: mentat-release [--tag=<v>] [--dry-run]" >&2
      exit 1 ;;
  esac
done

cd "$REPO_ROOT"

if [ -z "$TAG" ]; then
  LAST_TAG=$(git describe --tags --abbrev=0 2>/dev/null || echo "(no tags)")
  echo "mentat-release: last tag: $LAST_TAG"
  if [ "$LAST_TAG" != "(no tags)" ]; then
    COUNT=$(git rev-list "${LAST_TAG}..HEAD" --count 2>/dev/null || echo 0)
    echo "mentat-release: commits since $LAST_TAG: $COUNT"
    if [ "$COUNT" -gt 0 ]; then
      git log --oneline "${LAST_TAG}..HEAD"
    fi
  fi
  exit 0
fi

if ! echo "$TAG" | grep -qE '^v[0-9]+\.[0-9]+\.[0-9]+'; then
  echo "mentat-release: tag must match v<major>.<minor>.<patch> (got: $TAG)" >&2
  exit 1
fi

if git rev-parse "$TAG" >/dev/null 2>&1; then
  echo "mentat-release: tag '$TAG' already exists" >&2
  exit 1
fi

echo "mentat-release: creating tag $TAG at $(git rev-parse --short HEAD)"
if [ "$DRY_RUN" -eq 1 ]; then
  echo "mentat-release: dry-run — would run: git tag $TAG && git push origin $TAG"
  echo "mentat-release: dry-run — would bundle .agents/skills/vendor/ → mentat-vendor-${TAG}.tar.gz"
  echo "mentat-release: dry-run — would run: gh release create $TAG <tarball> --generate-notes --verify-tag"
  exit 0
fi

git tag "$TAG"
git push origin "$TAG"

# Bundle vendor/ into a release tarball so consumers without vendir can install.
VENDOR_DIR="$REPO_ROOT/.agents/skills/vendor"
if [ -d "$VENDOR_DIR" ] && command -v gh >/dev/null 2>&1; then
  TARBALL="/tmp/mentat-vendor-${TAG}.tar.gz"
  tar -czf "$TARBALL" -C "$REPO_ROOT/.agents/skills" vendor/
  gh release create "$TAG" "$TARBALL" \
    --title "$TAG" \
    --generate-notes \
    --verify-tag
  echo "mentat-release: release created — $TAG (vendor tarball attached)"
else
  echo "mentat-release: done — $TAG pushed (no vendor tarball: gh or vendor/ missing)"
fi
