{
  "name": "mentat",
  "image": "mcr.microsoft.com/devcontainers/base:bookworm",
  "features": {
    "ghcr.io/devcontainers/features/node:1": { "version": "22" },
    "ghcr.io/devcontainers/features/python:1": { "version": "3.11" }
  },
  "onCreateCommand": "apt-get update && apt-get install -y jq shellcheck && curl -LsSf https://astral.sh/uv/install.sh | sh",
  "postCreateCommand": "~/.local/bin/uv sync --group dev && npm install -g promptfoo",
  "workspaceFolder": "/workspaces",
  "runArgs": ["--init"],
  "remoteUser": "vscode"
}
