#!/bin/bash
# mentat-container-up — bring up the devcontainer for a worktree.
# Auto-detects image/Dockerfile/docker-compose shape; synthesizes devcontainer.json
# if absent. Deps: git, jq, docker. ADR 0004.
set -euo pipefail

[ -f "$PWD/.git" ] || { echo "mentat-container-up: must run from inside a git worktree" >&2; exit 2; }

WT="$PWD"
SLUG=$(basename "$WT")

# shellcheck source=/dev/null
. "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/lib/strict.sh"
# shellcheck source=/dev/null
. "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/lib/compose-synth.sh"

workspace_folder() {
  sed 's|//.*||g' "$WT/.devcontainer/devcontainer.json" \
    | jq -r --arg slug "$SLUG" '.workspaceFolder // ("/workspaces/" + $slug)'
}

ensure_safe_directory() {
  devcontainer exec \
    --workspace-folder "$WT" \
    --id-label "mentat_slug=$SLUG" \
    bash -lc "git config --global --add safe.directory $(printf %q "$1")" \
    >/dev/null 2>&1 || true
}

# Already running — safe.directory must fire every path (handoff Issue 4).
if [ -n "$(docker ps -q --filter "label=mentat_slug=$SLUG")" ]; then
  ensure_safe_directory "$(workspace_folder)"
  exit 0
fi

# Stopped container — start it.
STOPPED=$(docker ps -aq --filter "label=mentat_slug=$SLUG" --filter "status=exited")
if [ -n "$STOPPED" ]; then
  docker start "$STOPPED" >/dev/null
  ensure_safe_directory "$(workspace_folder)"
  exit 0
fi

# Cold start — synthesize devcontainer.json if absent.
if [ ! -d "$WT/.devcontainer" ]; then
  if [ ! -f "$WT/docker-compose.yml" ] && [ -f "$WT/docker-compose.yaml" ]; then
    ln -s docker-compose.yaml "$WT/docker-compose.yml"
  fi
  if [ -f "$WT/docker-compose.yml" ]; then
    synthesize_devcontainer
  elif ls "$WT"/Dockerfile* >/dev/null 2>&1; then
    synthesize_devcontainer_from_dockerfile
  else
    echo "mentat-container-up: no .devcontainer/, no docker-compose.yml, no Dockerfile in worktree" >&2
    exit 1
  fi
fi

WS="$(workspace_folder)"
GIT_TARGET=$(awk '{print $2}' "$WT/.git")
ROOT="${GIT_TARGET%/.git/worktrees/*}"

# Symlink gitignored dep dirs from main repo so cold worktrees skip reinstall.
# Python .venv excluded (interpreter paths bake in absolute cwd).
for d in vendor node_modules; do
  [ -d "$ROOT/$d" ] && [ ! -e "$WT/$d" ] && ln -s "$ROOT/$d" "$WT/$d"
done

[ -f "$ROOT/.env" ] && [ ! -e "$WT/.env" ] && cp "$ROOT/.env" "$WT/.env"

HAS_DOCKER_COMPOSE=0
if [ -f "$WT/docker-compose.yml" ]; then
  if sed 's|//.*||g' "$WT/.devcontainer/devcontainer.json" \
       | jq -e '.dockerComposeFile' >/dev/null 2>&1; then
    HAS_DOCKER_COMPOSE=1
  fi
fi

if [ "$HAS_DOCKER_COMPOSE" = 1 ]; then
  OFFSET=$(( 0x$(printf %s "$SLUG" | shasum | cut -c1-2) % 90 + 10 ))

  local_cnames=$(awk '
    /^  [a-zA-Z0-9._-]+:[[:space:]]*$/ {
      if (cur && has_cname) print cur
      s=$0; gsub(/^  /, "", s); gsub(/:.*/, "", s)
      cur=s; has_cname=0; next
    }
    cur && /container_name:/ { has_cname=1 }
    END { if (cur && has_cname) print cur }
  ' "$WT/docker-compose.yml")

  override="$WT/docker-compose.mentat.yml"
  if [ -n "$local_cnames" ] && [ ! -f "$override" ]; then
    printf 'services:\n' > "$override"
    while IFS= read -r svc; do
      [ -z "$svc" ] && continue
      printf '  %s: { container_name: !reset null }\n' "$svc" >> "$override"
    done <<< "$local_cnames"
  fi

  if [ -f "$WT/.env" ]; then
    MARK="# --- mentat per-worktree overrides"
    body=$(sed "/^${MARK}/,\$d" "$WT/.env")
    printf '%s\n' "$body" > "$WT/.env"

    port_overrides=$(grep -oE '\$\{([A-Z][A-Z0-9_]*):-([0-9]+)\}[[:space:]]*:' \
        "$WT/docker-compose.yml" \
      | sed 's/\${\([^:]*\):-\([0-9]*\)}.*/\1 \2/' \
      | sort -u \
      | awk -v offset="$OFFSET" '{ printf "%s=%d\n", $1, $2+offset }')

    if [ -n "$port_overrides" ]; then
      {
        printf '\n%s (slug=%s, offset=%d) ---\n' "$MARK" "$SLUG" "$OFFSET"
        printf '%s\n' "$port_overrides"
      } >> "$WT/.env"
    fi
  fi

  dcj="$WT/.devcontainer/devcontainer.json"
  if ! grep -q 'docker-compose.mentat.yml' "$dcj" \
     && [ -f "$WT/docker-compose.mentat.yml" ]; then
    tmp=$(sed 's|//.*||g' "$dcj" \
      | jq '.dockerComposeFile |= (if type == "array" then . else [.] end) + ["../docker-compose.mentat.yml"]')
    printf '%s\n' "$tmp" > "$dcj"
  fi
fi

devcontainer up \
  --workspace-folder "$WT" \
  --mount "type=bind,source=$ROOT/.git,target=$ROOT/.git" \
  --remote-env "GIT_DIR=$GIT_TARGET" \
  --remote-env "GIT_WORK_TREE=$WS" \
  --id-label "mentat_slug=$SLUG"

ensure_safe_directory "$WS"
