#!/bin/bash
# mentat-container-doctor — assert mentat's minimum deps inside the container.
# Does NOT check language toolchains — those are the target repo's contract.
set -euo pipefail

_LIB="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/lib"
. "$_LIB/strict.sh"

RC=0

check() {
  local label="$1" cmd="$2"
  if eval "$cmd" >/dev/null 2>&1; then
    echo "OK  $label"
  else
    echo "FAIL $label"
    RC=1
  fi
}

check "git"           "command -v git"
check "jq"            "command -v jq"
check "docker socket" "test -S /var/run/docker.sock"

exit "$RC"
