#!/usr/bin/env bash
# mentat-sync-check — fail if any upstream was not synced within the last 24h.
# Reads MENTAT_SYNC_LOG (default $HOME/.agents/mentat/logs/sync-upstream.jsonl).
set -euo pipefail

: "${MENTAT_SYNC_LOG:=$HOME/.agents/mentat/logs/sync-upstream.jsonl}"

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$HERE/../.." && pwd)"
MANIFEST="$REPO_ROOT/upstreams.jsonc"

_parse_names() {
  sed '/^[[:space:]]*\/\//d' "$MANIFEST" | jq -r '.upstreams[].name'
}

STALE=0
NOW=$(date +%s)
MAX_AGE=86400  # 24h in seconds

while IFS= read -r name; do
  if [ ! -f "$MENTAT_SYNC_LOG" ]; then
    echo "STALE: $name — sync log not found at $MENTAT_SYNC_LOG"
    STALE=1
    continue
  fi

  # JSONL: jq processes one object per line; || true prevents set -e kill on parse error
  LAST_TS=$(jq -r --arg n "$name" 'select(.upstream == $n) | .ts' "$MENTAT_SYNC_LOG" 2>/dev/null || true)
  LAST_TS=$(printf '%s\n' "$LAST_TS" | sort | tail -1)

  if [ -z "$LAST_TS" ]; then
    echo "STALE: $name — no sync entry in log"
    STALE=1
    continue
  fi

  # Parse ISO-8601 ts to epoch (portable: python3 fallback)
  if command -v python3 >/dev/null 2>&1; then
    LAST_EPOCH=$(python3 -c "import datetime, sys; \
      s=sys.argv[1].rstrip('Z'); \
      dt=datetime.datetime.fromisoformat(s); \
      print(int(dt.replace(tzinfo=datetime.timezone.utc).timestamp()))" "$LAST_TS" 2>/dev/null) || LAST_EPOCH=0
  else
    LAST_EPOCH=0
  fi

  AGE=$(( NOW - LAST_EPOCH ))
  if [ "$AGE" -gt "$MAX_AGE" ]; then
    DAYS=$(( AGE / 86400 ))
    echo "STALE: $name last sync ${DAYS}d ago (threshold: 1d)"
    STALE=1
  fi
done < <(_parse_names)

[ "$STALE" -eq 0 ]
