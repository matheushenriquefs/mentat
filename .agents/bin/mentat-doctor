#!/usr/bin/env bash
# mentat-doctor — bundle env + session diagnostics into a markdown file.
# Usage: mentat-doctor [<session-slug>] [--reason=<str>] [--since=<duration>]
# Output: ~/.agents/mentat/diagnoses/<ts>-<slug>.md
set -euo pipefail

_LIB="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/lib"
. "$_LIB/strict.sh"
. "$_LIB/audit.sh"

SLUG=""
REASON=""

AUDIT_TAIL_LINES=100
CONTAINER_TAIL_LINES=200
CHUNK_LOG_TAIL_LINES=200
CHUNK_STDOUT_TAIL_LINES=50

for arg in "$@"; do
  case "$arg" in
    --reason=*) REASON="${arg#*=}" ;;
    --) ;;
    -*) echo "usage: mentat-doctor [<session-slug>] [--reason=<str>]" >&2; exit 1 ;;
    *)  SLUG="$arg" ;;
  esac
done

LOG_DIR="${MENTAT_LOG_PATH:-$HOME/.agents/mentat/logs}"
REPO="${MENTAT_REPO:-$(basename "$(git rev-parse --show-toplevel 2>/dev/null || pwd)")}"

if [ -n "$SLUG" ]; then
  # Explicit slug: locate its audit file on disk (authoritative).
  CHUNK_LOG="$(find "$LOG_DIR" -type f -name "${SLUG}.jsonl" 2>/dev/null | sort -u | head -1 || true)"
  if [ -n "$CHUNK_LOG" ]; then
    SESSION_DIR="$(dirname "$CHUNK_LOG")"   # .../<REPO>/<SESSION>
    SESSION="$(basename "$SESSION_DIR")"
    REPO="$(basename "$(dirname "$SESSION_DIR")")"
  else
    # Slug given but no file — fall back to env-injected session (orchestrate sets these).
    SESSION="${MENTAT_SESSION:-}"
    if [ -z "$SESSION" ] || [ ! -d "$LOG_DIR/$REPO/$SESSION" ]; then
      echo "mentat-doctor: no chunk audit for slug '$SLUG' under $LOG_DIR; set MENTAT_SESSION or pass a slug whose ${SLUG}.jsonl exists" >&2
      exit 2
    fi
  fi
else
  # No slug: discover latest real-work session and run doctor for every chunk in it.
  SESSION="${MENTAT_SESSION:-}"
  if [ -z "$SESSION" ] || [ ! -d "$LOG_DIR/$REPO/$SESSION" ] || [[ "$SESSION" == manual-* ]]; then
    SESSION="$(ls -1t "$LOG_DIR/$REPO" 2>/dev/null | grep -v '^manual-' | head -1 || true)"
  fi
  [ -n "$SESSION" ] || { echo "mentat-doctor: no batch under $LOG_DIR/$REPO" >&2; exit 2; }
  # Iterate all chunk-owning driver logs (orchestrate or solo implement) in this session.
  shopt -s nullglob
  _driver_logs=("$LOG_DIR/$REPO/$SESSION"/mentat-orchestrate-*.jsonl
                "$LOG_DIR/$REPO/$SESSION"/mentat-implement-*.jsonl)
  if [ "${#_driver_logs[@]}" -eq 0 ]; then
    # Fallback: pick the newest chunk jsonl directly.
    _driver_logs=("$LOG_DIR/$REPO/$SESSION"/*.jsonl)
  fi
  for _f in "${_driver_logs[@]}"; do
    [ -f "$_f" ] || continue
    _slug="$(basename "$_f" .jsonl | sed -E 's/^mentat-(orchestrate|implement)-//')"
    "$0" "$_slug" --reason=session-rerun
  done
  exit 0
fi

# Resolve orchestrate driver log (most recent for this slug).
SESSION_LOG="$(find "$LOG_DIR" -type f -name "mentat-orchestrate-${SLUG}.jsonl" 2>/dev/null | sort | tail -1 || true)"

OUT_DIR="$HOME/.agents/mentat/diagnoses"
mkdir -p "$OUT_DIR"
TS="$(date -u +%Y%m%dT%H%M%SZ)"
OUT="$OUT_DIR/${TS}-${SLUG}.md"
# Version bump if file already exists (idempotent reruns)
if [ -f "$OUT" ]; then
  i=1
  while [ -f "${OUT%.md}-${i}.md" ]; do i=$((i+1)); done
  OUT="${OUT%.md}-${i}.md"
fi

_ver() { "$@" 2>/dev/null || echo "n/a"; }

_emit_versions() {
  echo "## Tool versions"
  echo "- mentat: $(_ver git -C "$(dirname "$_LIB")" describe --tags --always)"
  echo "- docker: $(_ver docker --version | head -1)"
  echo "- jq: $(_ver jq --version)"
  echo "- python: $(_ver python3 --version)"
  echo "- bash: ${BASH_VERSION:-n/a}"
  echo ""
}

_emit_system() {
  echo "## System"
  echo "- OS: $(_ver uname -s)"
  echo "- Kernel: $(_ver uname -r)"
  echo "- Arch: $(_ver uname -m)"
  echo "- Terminal: ${TERM:-n/a}"
  echo "- Shell: ${SHELL:-n/a}"
  echo ""
}

_emit_repro() {
  echo "## Repro"
  echo "- Holding branch: $(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/origin/||' || echo 'n/a')"
  echo "- Worktree branch: $(_ver git rev-parse --abbrev-ref HEAD)"
  echo "- Tip: $(_ver git rev-parse --short HEAD)"
  echo "- Session: ${SESSION}"
  echo "- Reason: ${REASON:-<not provided>}"
  echo ""
  echo "## Expected vs actual"
  echo "- Expected: <describe expected outcome>"
  echo "- Actual: <describe actual outcome>"
  echo ""
}

# G3-S9 (ADR-0010 §3): if any chunk audit row carries reason:hitl-ambiguity,
# emit a distinct verdict section naming the suspect. Operators reading the
# diagnosis must see "design call needed" instead of the generic placeholder —
# HITL is NOT implement-fail and must not be collapsed into it.
_emit_verdict() {
  local chunk_log="$LOG_DIR/$REPO/$SESSION/$SLUG.jsonl"
  [ -f "$chunk_log" ] || return 0
  local hitl_rows
  hitl_rows="$(jq -c 'select(.payload.reason == "hitl-ambiguity")' "$chunk_log" 2>/dev/null | head -1 || true)"
  if [ -n "$hitl_rows" ]; then
    echo "## Verdict — HITL ambiguity (hitl-ambiguity)"
    echo "- Suspect: ambiguous plan, AFK chunk needed a design call."
    echo "- This is NOT implement-fail — distinct from generic gate-fail (ADR-0010 §3)."
    echo "- Source: ADR-0010 (HITL routing) — adapter refused to guess on ambiguity."
    echo "- Cross-ref: G3-S9 (this section), G3-S8 (land.complete reason mapping)."
    echo "- Action: review the worktree, escalate to a design call; do not retry blindly."
    echo "- Audit row (first hitl-ambiguity match):"
    echo '```json'
    echo "$hitl_rows"
    echo '```'
    echo ""
  fi
}

_emit_logs() {
  echo "## Logs"
  if [ -n "$SESSION_LOG" ] && [ -f "$SESSION_LOG" ]; then
    echo "### Audit excerpt (last ${AUDIT_TAIL_LINES} events)"
    echo '```json'
    tail -"$AUDIT_TAIL_LINES" "$SESSION_LOG"
    echo '```'
  else
    echo "- Audit log: not found (slug: ${SLUG}, dir: ${LOG_DIR})"
  fi
  echo ""
  local chunk_log="$LOG_DIR/$REPO/$SESSION/$SLUG.jsonl"
  if [ -f "$chunk_log" ]; then
    echo "### Chunk audit tail (last ${CHUNK_LOG_TAIL_LINES} events)"
    echo '```json'
    tail -"$CHUNK_LOG_TAIL_LINES" "$chunk_log"
    echo '```'
  fi
  local chunk_stdout="${chunk_log%.jsonl}.stdout"
  if [ -f "$chunk_stdout" ]; then
    echo "### Chunk stdout tail (last ${CHUNK_STDOUT_TAIL_LINES} lines)"
    echo '```'
    tail -"$CHUNK_STDOUT_TAIL_LINES" "$chunk_stdout"
    echo '```'
  fi
  echo ""
  local container_id
  container_id="$(docker ps -q --filter "label=mentat_slug=${SLUG}" 2>/dev/null | head -1 || true)"
  if [ -n "$container_id" ]; then
    echo "### Container logs (last ${CONTAINER_TAIL_LINES} lines)"
    echo '```'
    docker logs "$container_id" --tail "$CONTAINER_TAIL_LINES" 2>&1 || true
    echo '```'
  fi
  echo ""
}

_emit_footer() {
  echo "## Regression"
  echo "- Last known good commit: <provide commit SHA>"
  echo "- Is regression: unknown"
  echo ""
  echo "## Stage"
  local last_event=""
  if [ -n "$SESSION_LOG" ] && [ -f "$SESSION_LOG" ]; then
    last_event="$(jq -r '.event // empty' "$SESSION_LOG" 2>/dev/null | tail -1 || true)"
  fi
  echo "- Phase: ${last_event:-unknown}"
  echo ""
  echo "## Non-determinism"
  echo "- determinism_warnings: [\"non_deterministic_inference\"]"
  echo "- Note: LLM execution is non-deterministic. Recorded sampling params allow"
  echo "  re-attempt with matching config but Mentat makes no replay guarantee."
}

{
  echo "# Diagnosis — ${SLUG}"
  echo ""
  _emit_versions
  _emit_system
  _emit_repro
  _emit_verdict
  _emit_logs
  _emit_footer
} > "$OUT.tmp"

# Privacy sanitization: strip KEY|TOKEN|SECRET|PASSWORD|API=<value> patterns
trap 'rm -f "$OUT.tmp"' EXIT
sed -E 's/(KEY|TOKEN|SECRET|PASSWORD|API)[^=]*=[^ ]*/\1=<redacted>/gi' "$OUT.tmp" > "$OUT"
rm -f "$OUT.tmp"
trap - EXIT

echo "mentat-doctor: diagnosis written to $OUT"
