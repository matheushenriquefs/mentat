#!/usr/bin/env bash
# mentat-install — install mentat harness into ~/.agents/.
# Syncs vendored upstreams then rsyncs .agents/ to ~/.agents/.
# ADR 0004.
set -euo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
. "$HERE/lib/strict.sh"

FORCE_DIRTY=0
FORCE_GATE=0
YES=0
DRY_RUN=0
OFFLINE=0

for arg in "$@"; do
  case "$arg" in
    --force-dirty) FORCE_DIRTY=1 ;;
    --force-gate)  FORCE_GATE=1 ;;
    --yes)         YES=1 ;;
    --dry-run)     DRY_RUN=1 ;;
    --offline)     OFFLINE=1 ;;
    *)
      echo "usage: mentat-install [--force-dirty] [--force-gate] [--yes] [--dry-run] [--offline]" >&2
      echo "  --offline  skip upstream vendor sync (use existing vendir.lock.yml)" >&2
      exit 1 ;;
  esac
done

REPO_ROOT="$(cd "$HERE/../.." && pwd)"
AGENTS_DIR="$REPO_ROOT/.agents"

if [ ! -d "$AGENTS_DIR" ]; then
  echo "mentat-install: .agents/ not found at $AGENTS_DIR" >&2
  exit 1
fi

cd "$REPO_ROOT"

if [ "$FORCE_DIRTY" -eq 0 ]; then
  UNCOMMITTED=$(git -C "$REPO_ROOT" status --porcelain "$AGENTS_DIR" 2>/dev/null | { grep -c '^[MADRCU?]' || true; })
  if [ "$UNCOMMITTED" -gt 0 ]; then
    echo "mentat-install: $UNCOMMITTED uncommitted change(s) in .agents/ — commit first or use --force-dirty" >&2
    exit 1
  fi
fi

TRACKED_FILES=$(git -C "$REPO_ROOT" ls-files "$AGENTS_DIR" 2>/dev/null) || TRACKED_FILES=""
if [ -n "$TRACKED_FILES" ]; then
  GATE_FAIL=0
  while IFS= read -r f; do
    [ -z "$f" ] && continue
    "$HERE/mentat-precommit" auto "$f" || GATE_FAIL=1
  done <<< "$TRACKED_FILES"
  if [ "$GATE_FAIL" -ne 0 ]; then
    echo "mentat-install: gate check failed — fix errors above before installing" >&2
    if [ "$FORCE_GATE" -eq 1 ]; then
      echo "mentat-install: WARNING: proceeding with --force-gate despite gate failure" >&2
    else
      exit 1
    fi
  fi
fi

# Sync vendored upstreams (unless --offline)
if [ "$OFFLINE" -eq 0 ]; then
  UPDATE_CMD="$HERE/mentat-update"
  if [ -x "$UPDATE_CMD" ]; then
    if [ "$DRY_RUN" -eq 1 ]; then
      echo "mentat-install: dry-run — would run: mentat-update"
    else
      echo "mentat-install: syncing vendored upstreams ..."
      if ! "$UPDATE_CMD"; then
        echo "mentat-install: WARNING: mentat-update failed (vendir not installed?). Skipping vendor sync." >&2
        echo "mentat-install: Install vendir: https://carvel.dev/vendir/docs/latest/install/" >&2
        echo "mentat-install: Re-run without --offline after installing vendir, or run: mentat-update" >&2
      fi
    fi
  fi
fi

RSYNC_ARGS=(-av -L
  --exclude='evals/'
  --exclude='.dmux-hooks/'
  --exclude='vendored/'
  --exclude='*.bak.*'
  --exclude='.DS_Store'
  --exclude='bin/mentat-release'
  --exclude='bin/mentat-install'
  --exclude='bin/mentat-update'
  --exclude='upstreams.jsonc'
  --exclude='upstreams.lock.jsonc'
  --exclude='.skill-lock.json'
  --exclude='plans/'
  --exclude='mentat/'
  --exclude='context/'
  --exclude='.dmux/'
  --exclude='.mentat/'
  --exclude='evals/'
  --exclude='skills/vendor/'
)

if [ "$DRY_RUN" -eq 1 ]; then
  RSYNC_ARGS+=(-n)
  echo "mentat-install: dry-run — no files will be written"
fi

rsync "${RSYNC_ARGS[@]}" "$AGENTS_DIR/" "$HOME/.agents/"

# Harness command symlinks — mentat-* only, never vendor content.
ln_safe() {
  local src="$1" dest="$2"
  if [ -e "$dest" ] && [ ! -L "$dest" ]; then
    echo "mentat-install: skip: $dest is real file/dir — refusing to clobber"
    return 0
  fi
  ln -sfn "$src" "$dest"
}
link_into() {
  local src="$1" dest="$2" glob="$3"
  [ -d "$dest" ] || return 0
  for f in "$src"/$glob; do
    [ -e "$f" ] || continue
    ln_safe "$f" "$dest/$(basename "$f")"
  done
}
link_into "$HOME/.agents/commands" "$HOME/.claude/commands" "mentat-*.md"
link_into "$HOME/.agents/commands" "$HOME/.codex/prompts"   "mentat-*.md"

# Harness skill symlinks — mentat-* + matt categories, never caveman vendor.
MENTAT_SKILLS_GLOB="mentat-*"
MATT_ROOT="$HOME/.agents/skills/vendor/mattpocock/skills/skills"
for harness_skill_dir in "$HOME/.claude/skills" "$HOME/.cursor/skills" "$HOME/.codex/skills"; do
  link_into "$HOME/.agents/skills" "$harness_skill_dir" "$MENTAT_SKILLS_GLOB"
  for cat in deprecated engineering in-progress misc personal productivity; do
    [ -d "$MATT_ROOT/$cat" ] || continue
    link_into "$MATT_ROOT/$cat" "$harness_skill_dir" "*"
  done
done

# Bin + docs umbrella symlinks per harness.
for hdir in "$HOME/.claude" "$HOME/.cursor" "$HOME/.codex"; do
  [ -d "$hdir" ] || continue
  ln_safe "$HOME/.agents/bin"  "$hdir/bin"
  ln_safe "$HOME/.agents/docs" "$hdir/docs"
done

echo "mentat-install: done"

# Orphan advisory: files present in ~/.agents/ but not in source tree.
# mentat-install never deletes. Review these and remove manually if stale.
ORPHANS=$(LC_ALL=C comm -23 \
  <(find "$HOME/.agents" -type f | LC_ALL=C sort) \
  <(cd "$AGENTS_DIR" && find . -type f | sed "s|^\./|$HOME/.agents/|" | LC_ALL=C sort) \
  2>/dev/null || true)
if [ -n "$ORPHANS" ]; then
  echo ""
  echo "mentat-install: orphan files (in ~/.agents/ but not in source — remove manually if stale):"
  echo "$ORPHANS"
fi
