#!/usr/bin/env bash
# mentat-sync-upstream — clone upstream at pin, rsync into vendor_path, diff vs prior.
# Usage: mentat-sync-upstream <name>
#        mentat-sync-upstream --print-credits   (emit CREDITS.md from upstreams.jsonc)
set -euo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$HERE/../.." && pwd)"
MANIFEST="$REPO_ROOT/upstreams.jsonc"

if [ ! -f "$MANIFEST" ]; then
  echo "mentat-sync-upstream: upstreams.jsonc not found at $MANIFEST" >&2
  exit 1
fi

_parse_manifest() {
  # Strip // comments then parse JSON
  sed '/^[[:space:]]*\/\//d' "$MANIFEST"
}

_print_credits() {
  echo "# Credits"
  echo ""
  echo "Vendored upstream dependencies used in this project."
  echo ""
  echo "| Name | URL | License | Pin | Description |"
  echo "|------|-----|---------|-----|-------------|"

  _parse_manifest | jq -r '.upstreams[] |
    "| " + .name +
    " | " + .url +
    " | " + (.license // "unknown") +
    " | `" + (.pin // "HEAD") + "`" +
    " | " + (.description // "") +
    " |"'

  echo ""
  echo "## Notices"
  echo ""

  # Aggregate NOTICE files from vendored dirs
  _parse_manifest | jq -r '.upstreams[].vendor_path' | while IFS= read -r vp; do
    notice="$REPO_ROOT/$vp/NOTICE"
    if [ -f "$notice" ]; then
      echo "### $(basename "$vp")"
      echo ""
      cat "$notice"
      echo ""
    fi
  done

  echo "_Generated by \`bin/mentat-sync-upstream --print-credits\`. Edit \`upstreams.jsonc\`, not this file._"
}

if [ "${1:-}" = "--print-credits" ]; then
  _print_credits
  exit 0
fi

NAME="${1:-}"
if [ -z "$NAME" ]; then
  echo "usage: mentat-sync-upstream <name> | --print-credits" >&2
  exit 1
fi

UPSTREAM=$(_parse_manifest | jq -e --arg n "$NAME" '.upstreams[] | select(.name == $n)') || {
  echo "mentat-sync-upstream: upstream '$NAME' not found in upstreams.jsonc" >&2
  exit 1
}

URL=$(echo "$UPSTREAM" | jq -r '.url')
PIN=$(echo "$UPSTREAM" | jq -r '.pin // "HEAD"')
VENDOR_PATH=$(echo "$UPSTREAM" | jq -r '.vendor_path')
SUBTREE=$(echo "$UPSTREAM" | jq -r '.subtree_path // ""')
COMMIT_FLAG=$(echo "$UPSTREAM" | jq -r '.commit')

# Guard against path traversal: vendor_path must resolve inside REPO_ROOT
# realpath -m (GNU) not available on macOS; use Python as portable fallback
if command -v python3 >/dev/null 2>&1; then
  FULL_VENDOR="$(python3 -c "import os,sys; print(os.path.normpath(os.path.join('$REPO_ROOT', sys.argv[1])))" "$VENDOR_PATH")"
else
  FULL_VENDOR="$(cd "$REPO_ROOT" && realpath -m "$VENDOR_PATH")"
fi
if [[ "$FULL_VENDOR" != "$REPO_ROOT"/* ]]; then
  echo "mentat-sync-upstream: vendor_path '$VENDOR_PATH' escapes repo root — refusing" >&2
  exit 1
fi

TMPDIR=$(mktemp -d)
trap 'rm -rf "$TMPDIR"' EXIT

echo "mentat-sync-upstream: cloning $NAME at $PIN ..."
git clone --depth=1 "$URL" "$TMPDIR/repo"

if [ "$PIN" != "HEAD" ]; then
  # Fetch the specific commit if shallow clone didn't get it
  git -C "$TMPDIR/repo" fetch --depth=1 origin "$PIN" 2>/dev/null || true
  if ! git -C "$TMPDIR/repo" checkout "$PIN" 2>/dev/null; then
    ACTUAL=$(git -C "$TMPDIR/repo" rev-parse HEAD)
    echo "mentat-sync-upstream: WARNING: could not checkout pin '$PIN'; at $ACTUAL" >&2
    echo "mentat-sync-upstream: verify pin is a reachable ref — aborting to avoid syncing wrong tree" >&2
    exit 1
  fi
fi

SRC="$TMPDIR/repo"
if [ -n "$SUBTREE" ]; then
  SRC="$TMPDIR/repo/$SUBTREE"
fi

if [ ! -d "$SRC" ]; then
  echo "mentat-sync-upstream: subtree_path '$SUBTREE' not found in cloned repo" >&2
  exit 1
fi

mkdir -p "$FULL_VENDOR"

echo "mentat-sync-upstream: syncing into $VENDOR_PATH ..."
rsync -av --delete "$SRC/" "$FULL_VENDOR/"

# Copy LICENSE and NOTICE if present at repo root
for f in LICENSE NOTICE; do
  [ -f "$TMPDIR/repo/$f" ] && cp "$TMPDIR/repo/$f" "$FULL_VENDOR/$f" || true
done

# Gitignore if commit: false
GITIGNORE="$REPO_ROOT/.gitignore"
if [ "$COMMIT_FLAG" = "false" ]; then
  if ! grep -qF "$VENDOR_PATH" "$GITIGNORE" 2>/dev/null; then
    echo "$VENDOR_PATH/" >> "$GITIGNORE"
    echo "mentat-sync-upstream: added $VENDOR_PATH/ to .gitignore"
  fi
else
  # Remove from gitignore if present (commit: true)
  if grep -qF "$VENDOR_PATH" "$GITIGNORE" 2>/dev/null; then
    sed -i.bak "\|$VENDOR_PATH|d" "$GITIGNORE" && rm -f "$GITIGNORE.bak"
    echo "mentat-sync-upstream: removed $VENDOR_PATH/ from .gitignore"
  fi
fi

echo "mentat-sync-upstream: done — review diff and integrate what you need"
