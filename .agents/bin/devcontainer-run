#!/bin/bash
# ~/.agents/bin/devcontainer-run — run one command INSIDE the worktree's
# devcontainer. The single seam through which all project-interpreter work
# (uv / ruff / pre-commit / python / php / node / test commands) must pass:
# the host runs none of it (ADR 0004). Callers must run devcontainer-up first;
# if the container is not running this script exits 99 rather than auto-starting.
# Deps: git, jq, docker. No language toolchain on host (ADR 0004).
set -euo pipefail

CMD="${*:-}"
[ -z "$CMD" ] && { echo "usage: devcontainer-run '<command>'" >&2; exit 2; }
[ -f "$PWD/.git" ] || { echo "devcontainer-run: must run from inside a git worktree" >&2; exit 2; }

WT="$PWD"
SLUG=$(basename "$WT")

workspace_folder() {
  sed 's|//.*||g' "$WT/.devcontainer/devcontainer.json" \
    | jq -r --arg slug "$SLUG" '.workspaceFolder // ("/workspaces/" + $slug)'
}

# Container not running → exit 99. Callers must devcontainer-up first.
if [ -z "$(docker ps -q --filter "label=dmux_slug=$SLUG")" ]; then
  echo "devcontainer-run: container not running for slug $SLUG (run devcontainer-up first)" >&2
  exit 99
fi

WS="$(workspace_folder)"

exec devcontainer exec \
  --workspace-folder "$WT" \
  --id-label "dmux_slug=$SLUG" \
  bash -lc "cd $(printf %q "$WS") && $CMD"
