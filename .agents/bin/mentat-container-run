#!/bin/bash
# mentat-container-run — exec one command inside the worktree's devcontainer.
# All project-interpreter work must pass through here. ADR 0004.
# Exits 99 if container not running (caller must mentat-container-up first).
#
# State invariants (slug, workspaceFolder) flow through lib/container-state.sh
# — see .agents/docs/container-state-design.md.
set -euo pipefail

# shellcheck source=/dev/null
. "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/lib/strict.sh"
# shellcheck source=/dev/null
. "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/lib/container-state.sh"

CMD="${*:-}"
[ -z "$CMD" ] && { echo "usage: mentat-container-run '<command>'" >&2; exit 2; }
[ -f "$PWD/.git" ] || { echo "mentat-container-run: must run from inside a git worktree" >&2; exit 2; }

SLUG="$(container_slug_for_cwd)"

if ! CID="$(container_id_for "$SLUG")"; then
  echo "mentat-container-run: container not running for slug $SLUG (run mentat-container-up first)" >&2
  exit 99
fi

# Use slug-based path — devcontainer.json workspaceFolder may differ (e.g. "mentat")
# but chunk containers mount the worktree at /workspaces/<slug>.
WS="/workspaces/$SLUG"

# Pre-flight: assert the workspaceFolder exists inside the container before
# `exec` replaces this process. Lib emits explicit stderr on miss; set -euo
# pipefail propagates the nonzero exit pointing the user to mentat-container-up.
ensure_workspace_folder "$WS"

exec docker exec --workdir "$WS" -u vscode "$CID" bash -lc "git config --global --add safe.directory '*' 2>/dev/null || true; $CMD"
