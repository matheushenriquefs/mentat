#!/usr/bin/env bash
# bin/mentat-precommit — dispatch per-class precommit check, invoked by lefthook.
# Usage: mentat-precommit <class> <file> [<file> ...]
set -euo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
. "$HERE/lib/strict.sh"
# shellcheck source=/dev/null
. "$HERE/lib/precommit-gates.sh"

CLASS="${1:?usage: mentat-precommit <class> <file> [...]}"
shift

fail=0
for f in "$@"; do
  [ -f "$f" ] || continue
  case "$CLASS" in
    adr)      gate_adr      "$f" || fail=1 ;;
    skill)    gate_skill    "$f" || fail=1 ;;
    command)  gate_command  "$f" || fail=1 ;;
    workflow) gate_workflow "$f" || fail=1 ;;
    shell)    gate_shell    "$f" || fail=1 ;;
    jsonc)    gate_jsonc    "$f" || fail=1 ;;
    jq)       gate_jq       "$f" || fail=1 ;;
    harness)  gate_harness  "$f" || fail=1 ;;
    auto)
      case "$f" in
        */docs/adr/*.md)              gate_adr      "$f" || fail=1 ;;
        */skills/*/SKILL.md)          gate_skill    "$f" || fail=1 ;;
        */commands/*.md)              gate_command  "$f" || fail=1 ;;
        */.github/workflows/*.yml|\
        */.github/workflows/*.yaml)   gate_workflow "$f" || fail=1 ;;
        */bin/lib/harness/*.sh)       gate_harness  "$f" || fail=1 ;;
        *.sh)                         gate_shell    "$f" || fail=1 ;;
        *.jsonc)                      gate_jsonc    "$f" || fail=1 ;;
        *.jq)                         gate_jq       "$f" || fail=1 ;;
        *) ;;  # no gate for this file type
      esac ;;
    *) echo "mentat-precommit: unknown class '$CLASS'" >&2; exit 1 ;;
  esac
done
exit "$fail"
