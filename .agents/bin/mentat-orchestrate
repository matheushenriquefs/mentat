#!/bin/bash
# mentat-orchestrate — thin driver. Dispatches mentat-fan-out -> mentat-land-queue
# -> mentat-final-review. Same external behavior (chunk count, audit envelope,
# eject layout) as pre-S9. ADR 0004 ADR 0011.
#
# Usage: mentat-orchestrate [--harness=<n>] [--model=<s>] [--dry-run]
#                       <holding-branch> <plan.md> [<plan.md> ...]
# Exit:  0 = all chunks landed; 1 = partial (>=1 eject);
#        >=2 = tool-level error (bad argv, missing config, plan-check fail).

_HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
_LIB="$_HERE/lib"
. "$_LIB/strict.sh"
. "$_LIB/log.sh"
. "$_LIB/here.sh"
. "$_LIB/config.sh"
. "$_LIB/audit.sh"
. "$_LIB/plan-validate.sh"
_LOG_PREFIX=mentat-orchestrate
die() { printf '[%s] ERROR %s\n' "$_LOG_PREFIX" "$*" >&2; exit 2; }

DRY_RUN=0; FLAGS=()
while [ "$#" -gt 0 ]; do
  case "$1" in
    --harness=*|--model=*) FLAGS+=("$1"); shift ;;
    --dry-run) DRY_RUN=1; shift ;;
    --) shift; break ;;
    -*) die "unknown flag $1 (usage: mentat-orchestrate [--harness=<n>] [--model=<s>] [--dry-run] <holding-branch> <plan.md> [...])" ;;
    *) break ;;
  esac
done

mentat_config_validate || die "invalid .mentat.jsonc — fix config before running"
[ "$#" -ge 1 ] || die "missing positional <holding-branch> (usage: mentat-orchestrate [flags] <holding-branch> <plan.md> [...])"
HOLDING="$1"; shift
[ "$#" -ge 1 ] || die "need at least one plan path"
for _p in "$@"; do mentat_plan_check "$_p" || die "plan check failed: $_p"; done

if [ "$DRY_RUN" -eq 1 ]; then
  log "dry-run: holding=$HOLDING flags=${FLAGS[*]:-}"
  for _p in "$@"; do log "dry-run: plan $_p"; done
  exit 0
fi

ROOT="$PWD"
: "${MENTAT_REPO:=$(basename "$ROOT")}"
: "${MENTAT_SESSION:=$(date +%s)-$$}"
export MENTAT_REPO MENTAT_SESSION
LAND_BASE="$(git -C "$ROOT" rev-parse "$HOLDING" 2>/dev/null || echo "$HOLDING")"

set +e
printf '%s\n' "$@" \
  | "$_HERE/mentat-fan-out" ${FLAGS[@]+"${FLAGS[@]}"} \
  | "$_HERE/mentat-land-queue" ${FLAGS[@]+"${FLAGS[@]}"} "$HOLDING"
_RC=("${PIPESTATUS[@]}")
set -e
RC_FAN="${_RC[1]}"; RC_LAND="${_RC[2]}"

if [ "$RC_FAN" -ge 2 ] || [ "$RC_LAND" -ge 2 ]; then
  die "tool-level failure (fan-out=$RC_FAN land-queue=$RC_LAND)"
fi
if [ "$RC_FAN" -eq 0 ] && [ "$RC_LAND" -eq 0 ]; then
  TIP="$(git -C "$ROOT" rev-parse "$HOLDING" 2>/dev/null || echo "$HOLDING")"
  "$_HERE/mentat-final-review" ${FLAGS[@]+"${FLAGS[@]}"} "$LAND_BASE" "$TIP" || true
  log "done. Push + PR manually (ADR 0002)."
  exit 0
fi
log "partial: fan-out=$RC_FAN land-queue=$RC_LAND. Repair ejected chunks before final-review (ADR 0004)."
exit 1
