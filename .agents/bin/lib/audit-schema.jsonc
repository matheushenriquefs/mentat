// audit-schema.jsonc — single source-of-truth for mentat audit envelope.
// Read by bash (bin/lib/audit.sh) and python (lib/audit_schema.py).
// Referenced by ADR-0009 (audit envelope). Bump `version` on breaking change.
//
// Envelope (fixed, all rows): {ts, agent, session, event, payload}
//   - ts:      ISO-8601 UTC (jq `now|todate`)
//   - agent:   bin slug emitting the row (e.g. mentat-orchestrate)
//   - session: $MENTAT_SESSION = <epoch>-<pid>
//   - event:   verb from `events` map below
//   - payload: object matching the verb's required/optional keys
//
// Rejection rule (S2): unknown event OR missing required field => row refused,
// nonzero exit, raw event spilled to stderr sidecar (see `sidecar.stderr`).
//
// Comment stripping: bash uses `sed 's|//.*$||'` then jq; python uses
// `json5`/`pyjson5` or the same strip pass before json.loads.
{
  "version": 1,

  "envelope": {
    "required": ["ts", "agent", "session", "event", "payload"],
    "ts_format": "iso8601-utc",
    "session_pattern": "^[0-9]+-[0-9]+$"
  },

  // Verb registry. Keys are the canonical event names. `actor` documents the
  // expected emitter (informational — not enforced). `required` / `optional`
  // list payload keys; payload type is always object unless noted.
  "events": {
    // --- mentat-plan ---------------------------------------------------------
    "plan.start":           {"actor": "mentat-plan",        "required": ["path"]},
    "plan.complete":        {"actor": "mentat-plan",        "required": ["path"]},

    // --- mentat-implement ----------------------------------------------------
    "implement.start":       {"actor": "mentat-implement",  "required": ["plan"]},
    "implement.preflight":   {"actor": "mentat-implement",  "required": ["slices"]},
    "implement.preflight.fail": {"actor": "mentat-implement","required": ["cwd","expected"]},
    "implement.complete":    {"actor": "mentat-implement",  "required": ["plan","outcome"], "optional": ["slices","verification"]},

    // --- mentat-rebase -------------------------------------------------------
    "rebase.start":         {"actor": "mentat-rebase",      "required": ["holding"]},
    "rebase.complete":      {"actor": "mentat-rebase",      "required": ["holding"]},
    "rebase.conflict":      {"actor": "mentat-rebase",      "required": ["holding"], "optional": ["conflicted_files","resume_cmd"]},

    // --- mentat-eval ---------------------------------------------------------
    "eval.start":           {"actor": "mentat-eval",        "required": ["skill"]},
    "eval.complete":        {"actor": "mentat-eval",        "required": ["skill"]},

    // --- mentat-release ------------------------------------------------------
    "release.start":        {"actor": "mentat-release",     "required": []},
    "release.complete":     {"actor": "mentat-release",     "required": []},

    // --- mentat-orchestrate --------------------------------------------------
    "orchestrate.start":    {"actor": "mentat-orchestrate", "required": ["args"]},
    // chunk.spawn: new in G1-S6 — one row per fanned-out chunk.
    "chunk.spawn":          {"actor": "mentat-orchestrate", "required": ["slug","plan"]},
    // land.complete: outcome enum = success | eject (reason qualifies eject).
    //   reason enum = rebase-conflict | gate-fail | not-ff | implement-fail
    //   conflicted_files / resume_cmd populated when reason == rebase-conflict (S10).
    "land.complete":        {"actor": "mentat-orchestrate", "required": ["slug","outcome","tip"], "optional": ["reason","conflicted_files","resume_cmd"]},
    // gate.fail: structured re-gate failure detail (orthogonal to land.complete).
    "gate.fail":            {"actor": "mentat-orchestrate", "required": ["slug","reason"], "optional": ["scores"]},
    // review.final: end-of-queue ADR-0003 composite verdict. Captured subprocess
    // stdout goes in `stdout` (truncated), stderr lives in sidecar `.stderr` file
    // pointed to by `stderr_path` (S4 — replaces raw `>> $jsonl` at lines 191,203).
    "review.final":         {"actor": "mentat-orchestrate", "required": ["reviewer","score","veto","findings"], "optional": ["base","tip","stdout","stderr_path"]},

    // --- mentat-update -------------------------------------------------------
    "sync.complete":        {"actor": "mentat-update",      "required": ["upstreams","changed"]},

    // --- mentat-diff ---------------------------------------------------------
    "diff.emit":            {"actor": "mentat-diff",        "required": ["base","tip","branch","files"]},

    // --- any actor -----------------------------------------------------------
    "rename.complete":      {"actor": "any",                "required": ["old","new"]},
    "staleref.sweep":       {"actor": "any",                "required": ["terms","hits"]},
    "review.dismiss":       {"actor": "any",                "required": ["reviewer","score","reason"]}
  },

  // Sidecar files — never inline in .jsonl. Path templates use the same
  // MENTAT_LOG_PATH / MENTAT_REPO / MENTAT_SESSION env vars as audit.sh.
  "sidecar": {
    "stderr": {
      "path_pattern": "${MENTAT_LOG_PATH}/${MENTAT_REPO}/${MENTAT_SESSION}/.stderr/${agent}-${slug}.stderr",
      "format":       "raw text, append-only (not JSON)",
      "created_on":   "first audit rejection OR first captured subprocess stderr",
      "rotation":     "follows mentat-logs-prune cadence (gzip >30d, archive >90d, delete >180d)"
    },
    "stdout": {
      "path_pattern": "${MENTAT_LOG_PATH}/${MENTAT_REPO}/${MENTAT_SESSION}/${agent}-${slug}.stdout",
      "format":       "raw harness output (opaque, pre-existing)",
      "rotation":     "follows mentat-logs-prune cadence"
    }
  }
}
